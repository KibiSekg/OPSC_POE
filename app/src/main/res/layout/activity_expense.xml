<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="5dp"
    tools:context=".Expense">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Amount"
        android:layout_margin="5dp"
        android:textSize="18sp"
        android:textStyle="bold"
        />

    <EditText
        android:id="@+id/etAmnt"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="R 0.00"
        android:layout_margin="5dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Category"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="5dp"
        />

    <EditText
        android:id="@+id/etCategory"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Enter Category (e.g. Transport, Food)"
        android:inputType="text"
        android:layout_margin="5dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Transaction type"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="5dp"
        />
    <EditText
        android:id="@+id/etTransactionType"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Income or Expense"
        android:inputType="text"
        android:layout_margin="5dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Date Of Transaction"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="5dp"
        />

    <EditText
        android:id="@+id/etTransactionDate"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="yyyy-mm-dd (Include hyphens)"
        android:inputType="date"
        android:layout_margin="5dp"
        />


    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Transaction"
        android:layout_margin="5dp"
        android:onClick="saveTransaction"
        android:layout_gravity="center"
        />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp">

        <Button
            android:id="@+id/btnHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:layout_margin="5dp"
            />

        <Button
            android:id="@+id/btnExpInc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exp/Inc"
            android:layout_margin="5dp"
            />

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:layout_margin="5dp"
            />

    </LinearLayout>



</LinearLayout>