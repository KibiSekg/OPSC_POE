<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="5dp"
    tools:context=".Profile">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:layout_margin="5dp"
            android:textSize="25sp"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Monthly Budget: "
            android:textSize="19sp"
            android:layout_margin="5dp"
            />

        <EditText
            android:id="@+id/etMonthlyBudget"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:hint="R 0.00"
            android:layout_margin="5dp"
            />


    </LinearLayout>

    <Button
        android:id="@+id/btnSetMonthlyBudg"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="Set"
        android:layout_margin="5dp"
        android:layout_gravity="center"
        android:onClick="setMonthlyBudget"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Balance"
            android:textSize="19sp"
            android:layout_margin="5dp"
            />

        <TextView
            android:id="@+id/tvMonthlyBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R 0.00"
            android:layout_margin="5dp"
            android:textSize="18sp"
            />
        
        <TextView
            android:id="@+id/etProfLossStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Transactions"
            android:layout_margin="5dp"
            />
        
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp">
    
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number Of Income"
                android:textSize="19sp"
                android:layout_margin="5dp"
                />
    
            <TextView
                android:id="@+id/tvNumOfInc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:layout_margin="5dp"
                android:textSize="18sp"
                />

        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="5dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number of Expenses"
                android:textSize="19sp"
                android:layout_margin="5dp"
                />
            <TextView
                android:id="@+id/tvNumOfExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:layout_margin="5dp"
                />
        </LinearLayout>

    </LinearLayout>
    

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp">

        <Button
            android:id="@+id/btnHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:layout_margin="5dp"
            />

        <Button
            android:id="@+id/btnExpInc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exp/Inc"
            android:layout_margin="5dp"
            />

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:layout_margin="5dp"
            />

    </LinearLayout>



</LinearLayout>